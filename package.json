{
  "name": "@run-iq/core",
  "version": "0.1.1",
  "description": "PPE — Parametric Policy Engine core",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ && prettier --check src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix && prettier --write src/ tests/"
  },
  "keywords": ["ppe", "policy-engine", "rules-engine", "parametric"],
  "author": "Abdou-Raouf ATARMLA",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "decimal.js": "^10.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
